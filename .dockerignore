# Exclude node modules from the host (they will be installed in the container)
node_modules

# Exclude logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Exclude version control directories
.git
.gitignore

# Exclude environment files that may contain secrets
.env
.env.local
.env.*.local
.env.sample

# Exclude documentation and markdown files
*.md

# Exclude test directories and files
tests
coverage

# Exclude Docker-specific files (optional)
Dockerfile
.dockerignore
